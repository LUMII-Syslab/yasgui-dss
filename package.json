{
  "name": "yasgui-dss",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "private": true,
  "dependencies": {
    "@triply/yasgui": "^4.2.28",
    "dotenv": "^17.3.1",
    "dss-client": "link:../dss-client",
    "ejs": "^4.0.1",
    "express": "^5.2.1"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc --project src",
    "build:client": "esbuild public_src/yasguiSetup.ts --bundle --outfile=public/scripts/yasguiSetup.js --sourcemap --format=esm",
    "start": "npm run build && node dist/index.js",
    "dev": "npx concurrently \"tsc --project src --watch\" \"esbuild public_src/yasguiSetup.ts --bundle --outfile=public/scripts/yasguiSetup.js --sourcemap --watch\"",
    "start:watch": "npx concurrently \"tsc --project src --watch\" \"esbuild public_src/yasguiSetup.ts --bundle --outfile=public/scripts/yasguiSetup.js --sourcemap --watch\" \"nodemon --watch dist dist/index.js\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/codemirror": "^5.60.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
